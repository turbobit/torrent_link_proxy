{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.4",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "storage",
    "scripting"
  ],
 
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Transmission URL Supporter"
  },
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
 
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
